# Snowflake 接続情報のテンプレート。
# このファイルを同ディレクトリに `secrets.toml` としてコピーし、実値を入れてください。
# （`secrets.toml` 本体は .gitignore 済み＝コミットされません）

[snowflake]
account = "ORG-ACCOUNT"     # 例: abcd-xy12345（Account Identifier）
user = "USERNAME"
password = "PASSWORD"
role = "ROLE"
warehouse = "WAREHOUSE"
database = "DATABASE"
schema = "SCHEMA"

# --- 代替の認証方式（必要なら password の代わりに）---
# SSO（ブラウザ認証）:
# authenticator = "externalbrowser"
#
# キーペア認証:
# private_key_file = "/absolute/path/to/rsa_key.p8"
